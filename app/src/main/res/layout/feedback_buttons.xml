<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="你对这个单词的印象如何？"
        android:textSize="15sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_forgot"
            style="@style/Widget.WordMemo.FeedbackButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:minWidth="0dp"
            android:text="忘记"
            app:backgroundTint="@color/feedback_forgot"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_hard"
            style="@style/Widget.WordMemo.FeedbackButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:minWidth="0dp"
            android:text="困难"
            app:backgroundTint="@color/feedback_hard"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_normal"
            style="@style/Widget.WordMemo.FeedbackButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:minWidth="0dp"
            android:text="一般"
            app:backgroundTint="@color/feedback_normal"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_good"
            style="@style/Widget.WordMemo.FeedbackButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:minWidth="0dp"
            android:text="不错"
            app:backgroundTint="@color/feedback_good"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_perfect"
            style="@style/Widget.WordMemo.FeedbackButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:minWidth="0dp"
            android:text="完美"
            app:backgroundTint="@color/feedback_perfect"
            app:cornerRadius="12dp" />
    </LinearLayout>
</LinearLayout>
